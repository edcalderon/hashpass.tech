{
  "defaults": {
    "sourceRepository": "hashpass-tech/hashpass.tech",
    "releaseBranches": {
      "development": "develop",
      "production": "main"
    },
    "directusUrls": {
      "development": "https://sso-dev.hashpass.co",
      "production": "https://sso.hashpass.co"
    },
    "supabaseRefs": {
      "development": "fxgftanraszjjyeidvia",
      "production": "fxgftanraszjjyeidvia"
    },
    "apiDomains": {
      "development": "api-dev.hashpass.tech",
      "production": "api.hashpass.tech"
    },
    "apiBaseUrls": {
      "development": "https://api-dev.hashpass.tech/api",
      "production": "https://api.hashpass.tech/api"
    },
    "lambda": {
      "region": "us-east-1",
      "functions": {
        "development": "hashpass-api-dev",
        "production": "hashpass-api-prod"
      }
    },
    "headersFile": "packages/infra/terraform/stacks/aws/custom-headers.blockchainsummit.yml"
  },
  "tenants": {
    "core": {
      "label": "hashpass.tech",
      "appType": "expo",
      "amplify": {
        "appId": "dy8duury54wam",
        "region": "us-east-2"
      },
      "frontendUrls": {
        "development": "https://dev.hashpass.tech",
        "production": "https://hashpass.tech"
      },
      "supabaseRefs": {
        "development": "fxgftanraszjjyeidvia",
        "production": "mnnqryrdlhddorqsrtbn"
      }
    },
    "club": {
      "label": "hashpass.club",
      "appType": "next",
      "appName": "HashPass Club",
      "supportEmail": "hello@hashpass.club",
      "amplify": {
        "appIdEnv": "HASHPASS_CLUB_AMPLIFY_APP_ID",
        "region": "us-east-2"
      },
      "frontendUrls": {
        "development": "https://club-dev.hashpass.tech",
        "production": "https://hashpass.club"
      }
    },
    "club-dev": {
      "label": "hashpass.club (dev)",
      "appType": "next",
      "appName": "HashPass Club",
      "supportEmail": "hello@hashpass.club",
      "amplify": {
        "appIdEnv": "HASHPASS_CLUB_DEV_AMPLIFY_APP_ID",
        "region": "us-east-2"
      },
      "frontendUrls": {
        "development": "https://club-dev.hashpass.tech",
        "production": "https://club-dev.hashpass.tech"
      }
    },
    "bsl": {
      "label": "bsl.hashpass.tech",
      "appType": "expo",
      "amplify": {
        "appId": "dy8duury54wam",
        "region": "us-east-2"
      },
      "frontendUrls": {
        "development": "https://bsl-dev.hashpass.tech",
        "production": "https://bsl.hashpass.tech"
      },
      "supabaseEnv": {
        "development": {
          "publicUrl": "EXPO_PUBLIC_BSL_SUPABASE_URL_DEV",
          "publicKey": "EXPO_PUBLIC_BSL_SUPABASE_KEY_DEV",
          "serviceRoleKey": "BSL_SUPABASE_SERVICE_ROLE_KEY_DEV",
          "databaseUrl": "BSL_SUPABASE_DB_URL_DEV"
        },
        "production": {
          "publicUrl": "EXPO_PUBLIC_BSL_SUPABASE_URL_PROD",
          "publicKey": "EXPO_PUBLIC_BSL_SUPABASE_KEY_PROD",
          "serviceRoleKey": "BSL_SUPABASE_SERVICE_ROLE_KEY_PROD",
          "databaseUrl": "BSL_SUPABASE_DB_URL_PROD"
        }
      },
      "supabaseRefs": {
        "development": "fxgftanraszjjyeidvia",
        "production": "mnnqryrdlhddorqsrtbn"
      }
    },
    "blockchainsummit": {
      "label": "blockchainsummit.hashpass.lat",
      "appType": "expo",
      "amplify": {
        "appId": "d951nuj7hrqeg",
        "region": "sa-east-1"
      },
      "frontendUrls": {
        "development": "https://blockchainsummit-dev.hashpass.lat",
        "production": "https://blockchainsummit.hashpass.lat"
      },
      "supabaseEnv": {
        "development": {
          "publicUrl": "EXPO_PUBLIC_BSL_SUPABASE_URL_DEV",
          "publicKey": "EXPO_PUBLIC_BSL_SUPABASE_KEY_DEV",
          "serviceRoleKey": "BSL_SUPABASE_SERVICE_ROLE_KEY_DEV",
          "databaseUrl": "BSL_SUPABASE_DB_URL_DEV"
        },
        "production": {
          "publicUrl": "EXPO_PUBLIC_BSL_SUPABASE_URL_PROD",
          "publicKey": "EXPO_PUBLIC_BSL_SUPABASE_KEY_PROD",
          "serviceRoleKey": "BSL_SUPABASE_SERVICE_ROLE_KEY_PROD",
          "databaseUrl": "BSL_SUPABASE_DB_URL_PROD"
        }
      },
      "supabaseRefs": {
        "development": "fxgftanraszjjyeidvia",
        "production": "mnnqryrdlhddorqsrtbn"
      }
    }
  }
}
