# HashPass web site target-account pipeline

aws_region   = "us-east-2"
name_prefix  = "hashpass"
environment  = "production"
repository   = "hashpass-tech/hashpass.tech"
branch_name  = "main"

# Create the connection with:
#   TARGET_AWS_ACCOUNT_ID=952191196420 \
#   AWS_REGION=us-east-2 \
#   packages/tools/scripts/provision-infra-connection.sh
connection_arn = "arn:aws:codeconnections:us-east-2:123456789012:connection/example"

# Production web build inputs. These are public values but should stay outside git.
supabase_url      = "https://mnnqryrdlhddorqsrtbn.supabase.co"
supabase_key      = "<EXPO_PUBLIC_SUPABASE_KEY_PROD>"
google_client_id  = "<GOOGLE_CLIENT_ID>"
ga_measurement_id = "G-2JCRQCH0R1"

# Development web build inputs. Use the dev Supabase project so the branch
# pipeline tests against the development auth/database path.
supabase_url_dev = "https://fxgftanraszjjyeidvia.supabase.co"
supabase_key_dev = "<EXPO_PUBLIC_SUPABASE_KEY_DEV>"

build_action_provider_name = "hashpass-ec2-build"
build_action_version       = "2"
build_action_timeout       = 60
build_script_path          = "packages/tools/scripts/build-static-site.sh"
build_output_directory     = "dist/client"
deploy_script_path         = "packages/tools/scripts/deploy-static-site.sh"
deploy_mode                = "direct"

build_worker_instance_type           = "m6i.large"
build_worker_instance_count          = 1
build_worker_root_volume_size_gb     = 100
build_worker_associate_public_ip_address = true
build_worker_allowed_ssh_cidrs       = []
build_worker_detailed_monitoring     = true

# Enable this once the target account has a GitHub Actions OIDC provider and
# you want the monitor workflow to start/stop the EC2 worker automatically.
enable_github_actions_worker_control = true
create_github_oidc_provider          = false

# Production CloudFront for hashpass.tech. Request/validate the ACM certificate
# in us-east-1, then paste the issued ARN here before enabling the cutover.
site_route53_zone_name   = "hashpass.tech"
site_custom_domain_name  = "hashpass.tech"
site_acm_certificate_arn = ""

enable_cloudfront = true
dev_enable_cloudfront = false

# The development pipeline deploys from develop and stays separate from the
# production pipeline in the same Terraform state. The dev hostname now lives
# inside the parent hashpass.tech zone in the target account.
dev_branch_name = "develop"
dev_route53_zone_name = "hashpass.tech"
dev_custom_domain_name = "dev.hashpass.tech"

# Leave these unset unless you need fixed bucket names. Terraform will use
# unique generated names, and Route 53 can still alias to the S3 website
# endpoint of a bucket with any name.
# site_bucket_name     = ""
# dev_site_bucket_name = ""

# If CloudFront is unavailable in the target account, use literal A records for
# the S3 website endpoint instead of Route 53 alias records. Keep these empty
# when CloudFront is enabled.
# site_route53_a_records = []
# dev_route53_a_records = [
#   "3.5.88.53",
#   "3.5.88.112",
#   "3.5.133.254",
#   "3.5.130.101",
#   "52.219.179.88",
#   "3.5.132.48",
#   "52.219.98.72",
#   "3.5.93.118",
# ]

# Artifact buckets can keep the generated names unless you want to pin them.
# artifact_bucket_name     = "hashpass-production-pipelines-952191196420-us-east-2"
# dev_artifact_bucket_name = "hashpass-dev-pipelines-952191196420-us-east-2"

# Additional build environment variables if required by the app bundle.
build_environment_overrides = {
  EXPO_PUBLIC_NATIVE_GOOGLE_SIGNIN = "false"
}

tags = {
  Project = "hashpass"
  Owner   = "platform"
}
