{
  "name": "@hashpass/infra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "build:club-docs-site": "bash scripts/build-club-docs-site.sh",
    "dev": "sst dev",
    "deploy:dev": "bash ../../packages/tools/scripts/deploy-sst-with-unlock.sh dev",
    "deploy:prod": "bash ../../packages/tools/scripts/deploy-sst-with-unlock.sh production",
    "deploy:club-docs:prod": "HASHPASS_INFRA_TARGET=club-docs bash ../../packages/tools/scripts/deploy-sst-with-unlock.sh production",
    "doctor": "infra doctor --target .",
    "clean": "rm -rf .sst dist"
  },
  "dependencies": {
    "@lsts_tech/infra": "^1.0.3",
    "sst": "^3.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "~5.8.3"
  }
}
