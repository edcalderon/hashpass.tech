{
  "name": "hashpass.tech",
  "main": "index.js",
  "version": "1.8.145",
  "packageManager": "pnpm@9.15.5",
  "pnpm": {
    "patchedDependencies": {
      "react-native-css-interop@0.2.1": "patches/react-native-css-interop@0.2.1.patch"
    }
  },
  "scripts": {
    "start": "pnpm --filter hashpass-mobile-app start",
    "start:mobile": "pnpm --filter hashpass-mobile-app start",
    "start:club": "pnpm --filter hashpass-club-web start",
    "start:reset": "pnpm --filter hashpass-mobile-app start:reset",
    "android": "pnpm --filter hashpass-mobile-app android",
    "android:bundle": "pnpm --filter hashpass-mobile-app android:bundle",
    "android:bundle:dev": "pnpm --filter hashpass-mobile-app android:bundle:dev",
    "android:publish": "pnpm --filter hashpass-mobile-app android:publish",
    "android:publish:dev": "pnpm --filter hashpass-mobile-app android:publish:dev",
    "android:release": "pnpm --filter hashpass-mobile-app android:release",
    "android:release:dev": "pnpm --filter hashpass-mobile-app android:release:dev",
    "android:release:alpha": "pnpm --filter hashpass-mobile-app android:release:alpha",
    "android:release:eas": "pnpm --filter hashpass-mobile-app android:release:eas",
    "android:release:eas:dev": "pnpm --filter hashpass-mobile-app android:release:eas:dev",
    "android:release:fastlane": "pnpm --filter hashpass-mobile-app android:release:fastlane",
    "android:release:fastlane:dev": "pnpm --filter hashpass-mobile-app android:release:fastlane:dev",
    "eas:mobile:sync": "node packages/tools/scripts/sync-mobile-eas-env.js --env production",
    "eas:mobile:sync:dev": "node packages/tools/scripts/sync-mobile-eas-env.js --env development",
    "eas:mobile:sync:prod": "node packages/tools/scripts/sync-mobile-eas-env.js --env production",
    "ios": "pnpm --filter hashpass-mobile-app ios",
    "web": "pnpm --filter hashpass-mobile-app web",
    "test": "pnpm --dir apps/mobile-app test",
    "env:propagate": "node packages/tools/scripts/propagate-env.js",
    "env:sync": "node packages/tools/scripts/sync-env.js",
    "typecheck": "node packages/tools/scripts/typecheck-changed.mjs",
    "dev": "npm run env:propagate local && pnpm --filter hashpass-mobile-app dev",
    "dev:mobile": "npm run env:propagate local && pnpm --filter hashpass-mobile-app dev",
    "dev:club": "pnpm --filter hashpass-club-web dev",
    "dev:web-app": "pnpm --filter hashpass-club-web dev",
    "dev:directus": "pnpm --filter hashpass-directus dev",
    "dev:all": "npm run env:propagate local && bash ./packages/tools/scripts/dev-all.sh",
    "infra:dev": "pnpm --filter @hashpass/infra run dev",
    "infra:deploy:dev": "pnpm --filter @hashpass/infra run deploy:dev",
    "infra:deploy:prod": "pnpm --filter @hashpass/infra run deploy:prod",
    "infra:hashpass-web:plan": "bash packages/infra/terraform/scripts/stack.sh hashpass-web plan",
    "infra:hashpass-web:apply": "bash packages/infra/terraform/scripts/stack.sh hashpass-web apply",
    "infra:hashpass-web:destroy": "bash packages/infra/terraform/scripts/stack.sh hashpass-web destroy",
    "infra:doctor": "pnpm --filter @hashpass/infra run doctor",
    "infra:mobile-release:plan": "bash packages/infra/terraform/scripts/stack.sh mobile-release plan",
    "infra:mobile-release:apply": "bash packages/infra/terraform/scripts/stack.sh mobile-release apply",
    "infra:mobile-release:destroy": "bash packages/infra/terraform/scripts/stack.sh mobile-release destroy",
    "infra:mobile-release:validate": "bash packages/infra/terraform/scripts/stack.sh mobile-release validate",
    "release:infra": "node packages/tools/scripts/release-infra-pipeline.js",
    "release:infra:patch": "node packages/tools/scripts/release-infra-pipeline.js --env production --bump patch",
    "release:infra:dev": "node packages/tools/scripts/release-infra-pipeline.js --env development --bump patch",
    "release:infra:prod": "node packages/tools/scripts/release-infra-pipeline.js --env production --bump patch",
    "infra:provision-connection": "bash packages/tools/scripts/provision-infra-connection.sh",
    "infra:provision-pipelines": "bash packages/tools/scripts/provision-infra-pipelines.sh",
    "release:infra:test": "bash packages/tools/scripts/test-release-infra-flow.sh",
    "build:web": "npm run env:propagate ${BUILD_ENV:-production} && pnpm --filter hashpass-mobile-app build && npm run postbuild:web",
    "build:mobile": "npm run env:propagate ${BUILD_ENV:-production} && pnpm --filter hashpass-mobile-app build && npm run postbuild:web",
    "build:club": "pnpm --filter hashpass-club-web build",
    "build:storybook": "storybook build -o storybook-static || echo 'Storybook not available, skipping build'",
    "build:all": "npm run build:mobile && npm run build:club",
    "postbuild:web": "rm -rf dist/client dist/server && mkdir -p dist/client dist/server && if [ -d apps/mobile-app/dist/client ]; then cp -R apps/mobile-app/dist/client/. dist/client/; if [ -d apps/mobile-app/dist/server ]; then cp -R apps/mobile-app/dist/server/. dist/server/; fi; elif [ -d apps/mobile-app/dist/server ]; then cp -R apps/mobile-app/dist/server/. dist/server/; elif [ -d apps/mobile-app/dist ]; then cp -R apps/mobile-app/dist/. dist/client/; fi && if [ -f dist/server/index.html ] && [ ! -f dist/client/index.html ]; then cp dist/server/index.html dist/client/index.html; fi && if [ -d storybook-static ]; then mkdir -p dist/client/storybook && cp -r storybook-static/* dist/client/storybook/; else echo 'Storybook static directory not found, skipping copy'; fi && mkdir -p dist/client/config && cp apps/mobile-app/config/versions.json dist/client/config/versions.json 2>/dev/null || true && cp apps/mobile-app/public/sw.js dist/client/sw.js 2>/dev/null || true",
    "prebuild": "rm -rf dist",
    "lint": "pnpm --filter hashpass-mobile-app lint",
    "deploy:directus": "bash packages/tools/scripts/deploy-directus.sh",
    "db:migrate": "node packages/tools/scripts/migrate-tenant-db.mjs",
    "db:migrate:bsl:prod": "node packages/tools/scripts/migrate-tenant-db.mjs --profile bsl-production",
    "db:migrate:bsl:prod:dry": "node packages/tools/scripts/migrate-tenant-db.mjs --profile bsl-production --dry-run",
    "deploy:staging": "npm run env:propagate staging && npm run env:sync staging && pnpm --filter hashpass-mobile-app build && npm run deploy:directus && netlify deploy --prod",
    "deploy:prod": "npm run env:propagate production && npm run env:sync production && npm run build:web && npm run deploy:directus && netlify deploy --prod",
    "deploy": "npm run deploy:prod",
    "deploy:web:s3": "npm run build:web && bash packages/tools/scripts/deploy-static-site.sh",
    "deploy:cloudflare": "npm run env:propagate production && npm run env:sync production && npm run build:web && npx wrangler pages deploy ./dist/client --project-name=hashpass",
    "seed:bslatam": "node packages/tools/scripts/util/seed-bslatam.mjs",
    "test:e2e:bslatam": "node ./apps/mobile-app/tests/bslatam/e2e.mjs",
    "match:speakers": "node packages/tools/scripts/match-users-to-speakers-update-vip.mjs",
    "grant:lukas": "node packages/tools/scripts/grant-1-luka-to-all-users.mjs",
    "amplify:push": "amplify push",
    "amplify:deploy": "amplify publish",
    "amplify:update-source": "bash packages/tools/scripts/update-amplify-source-repo.sh",
    "amplify:update-source:club": "bash packages/tools/scripts/update-amplify-source-repo.sh --tenant club",
    "amplify:update-source:club-dev": "bash packages/tools/scripts/update-amplify-source-repo.sh --tenant club-dev",
    "version:update": "node packages/tools/scripts/update-version.mjs",
    "update-readme": "pnpm exec versioning update-readme --readme README.md --changelog CHANGELOG.md --pkg package.json",
    "readme:sync": "pnpm run update-readme",
    "version:bump": "node packages/tools/scripts/version-bump.js",
    "release": "node packages/tools/scripts/release.js",
    "release:native": "node packages/tools/scripts/set-native-version.js",
    "release:patch": "node packages/tools/scripts/release.js patch",
    "release:minor": "node packages/tools/scripts/release.js minor",
    "release:major": "node packages/tools/scripts/release.js major",
    "release:promote": "node packages/tools/scripts/release.js patch --promote",
    "release:unified": "node packages/tools/scripts/release.js",
    "parameters:setup": "bash packages/tools/scripts/util/setup-parameters.sh create",
    "parameters:verify": "bash packages/tools/scripts/util/setup-parameters.sh verify",
    "parameters:list": "bash packages/tools/scripts/util/setup-parameters.sh list",
    "lambda:test": "RESPONSE_FILE=$(mktemp /tmp/hashpass-lambda-response.XXXXXX.json) && aws lambda invoke --function-name agendaMonitor --payload '{\"force\": true}' \"$RESPONSE_FILE\" && cat \"$RESPONSE_FILE\" && rm -f \"$RESPONSE_FILE\"",
    "deploy:amplify": "npm run build:web && npm run amplify:deploy",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "upload:email-assets": "node packages/tools/scripts/upload-email-assets-to-s3.js",
    "screenshots:email": "node packages/tools/scripts/capture-email-screenshots.js",
    "screenshots:speaker": "node packages/tools/scripts/capture-speaker-screenshots.js",
    "test:all-emails": "node packages/tools/scripts/test-all-emails.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "storybook:serve": "npx serve storybook-static",
    "docs:dev": "pnpm --filter hashpass-docs dev",
    "docs:build": "pnpm --filter hashpass-docs build",
    "docs:serve": "pnpm --filter hashpass-docs serve",
    "docs:deploy:netlify": "pnpm --filter hashpass-docs build && netlify deploy --prod --dir=apps/docs/build",
    "release:pipeline": "node packages/tools/scripts/release-pipeline.js",
    "release:dev": "node packages/tools/scripts/release-pipeline.js --env development --tenant core",
    "release:prod": "node packages/tools/scripts/release-pipeline.js --env production --tenant core",
    "release:core:dev": "node packages/tools/scripts/release-pipeline.js --env development --tenant core",
    "release:core:prod": "node packages/tools/scripts/release-pipeline.js --env production --tenant core",
    "release:bsl:dev": "node packages/tools/scripts/release-pipeline.js --env development --tenant blockchainsummit",
    "release:bsl:prod": "node packages/tools/scripts/release-pipeline.js --env production --tenant blockchainsummit",
    "release:club": "node packages/tools/scripts/release-pipeline.js --env production --tenant club",
    "release:club-dev": "node packages/tools/scripts/release-pipeline.js --env development --tenant club-dev",
    "version:club:web": "node packages/tools/scripts/update-club-web-version.mjs",
    "release:club:web": "node packages/tools/scripts/release-club-web.js patch",
    "release:club:web:patch": "node packages/tools/scripts/release-club-web.js patch",
    "release:all:dev": "node packages/tools/scripts/release-pipeline.js --env development --all-tenants",
    "release:all:prod": "node packages/tools/scripts/release-pipeline.js --env production --all-tenants",
    "prepare": "node -e \"const fs = require('fs'); if (process.env.CI || process.env.NPM_CONFIG_PRODUCTION || process.env.NODE_ENV === 'production' || !fs.existsSync('.git')) { process.exit(0); } process.exit(1);\" || husky"
  },
  "expo": {
    "extra": {
      "EXPO_PUBLIC_API_BASE_URL": "https://api.hashpass.tech/api"
    }
  },
  "jest": {
    "preset": "jest-expo"
  },
