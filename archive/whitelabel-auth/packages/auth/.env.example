# Local Development Environment for @whitelabel/auth
# Copy this file to .env and fill in your values

# =============================================================================
# SUPABASE CONFIGURATION (Primary Provider)
# =============================================================================
# For local development with Docker Compose:
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=changeme

# For cloud Supabase (production):
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# DIRECTUS CONFIGURATION (Secondary/OAuth Provider)
# =============================================================================
# For local development with Docker Compose:
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
DIRECTUS_STATIC_TOKEN=your-directus-static-token

# For cloud Directus (production):
# NEXT_PUBLIC_DIRECTUS_URL=https://your-directus-instance.com
# DIRECTUS_STATIC_TOKEN=your-production-token

# =============================================================================
# OAUTH PROVIDER CONFIGURATION
# =============================================================================
# Google OAuth - Required for Google Sign-In
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth - Required for GitHub Sign-In
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Facebook OAuth (optional)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Twitter OAuth (optional)
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Apple OAuth (optional - requires Apple Developer account)
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="HashPass Auth Test"

# Allowed redirect URLs for OAuth callbacks (comma-separated)
ALLOWED_REDIRECT_URLS=http://localhost:3000/auth/callback,http://localhost:3001/auth/callback

# =============================================================================
# WALLET AUTHENTICATION CONFIGURATION
# =============================================================================
# Ethereum Configuration
ETHEREUM_CHAIN_ID=1
# ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your-infura-key

# Solana Configuration
SOLANA_NETWORK=mainnet-beta
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# =============================================================================
# SYNC CONFIGURATION
# =============================================================================
# Sync strategy: webhook, polling, or realtime
SYNC_STRATEGY=webhook
SYNC_ENABLED=true
SYNC_CONFLICT_RESOLUTION=supabase-wins

# =============================================================================
# DATABASE CONFIGURATION (for local Docker)
# =============================================================================
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# =============================================================================
# JWT SECRETS (for local development)
# =============================================================================
# These are auto-generated in docker-compose but can be overridden
JWT_SECRET=super-secret-jwt-token-for-local-dev-only
DIRECTUS_KEY=changeme
DIRECTUS_SECRET=changeme

# =============================================================================
# SECURITY SETTINGS
# =============================================================================
# Set to true to require email verification before allowing access
REQUIRE_EMAIL_VERIFICATION=false

# Maximum sessions per user
MAX_SESSIONS_PER_USER=5

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
# Test user credentials (for automated testing)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=test-password-123

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable specific auth methods
ENABLE_EMAIL_AUTH=true
ENABLE_OAUTH=true
ENABLE_WALLET_AUTH=true
ENABLE_MAGIC_LINK=true
ENABLE_OTP=true
