{
  "name": "@whitelabel/auth",
  "version": "1.0.0",
  "description": "Infrastructure-agnostic authentication with Supabase, Directus, and wallet support",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./react-native": {
      "import": "./dist/react-native.js",
      "types": "./dist/react-native.d.ts"
    },
    "./wallet": {
      "import": "./dist/wallet.js",
      "types": "./dist/wallet.d.ts"
    }
  },
  "files": [
    "dist",
    "templates",
    "infra"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/react.ts src/react-native.ts src/wallet.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.81.1",
    "siwe": "^2.3.0",
    "ethers": "^6.11.0",
    "@solana/web3.js": "^1.91.0",
    "bs58": "^5.0.0",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "~5.8.3",
    "vitest": "^1.3.0"
  },
  "keywords": [
    "authentication",
    "supabase",
    "directus",
    "oauth",
    "wallet",
    "ethereum",
    "solana",
    "siwe",
    "white-label"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourorg/whitelabel-auth"
  },
  "publishConfig": {
    "access": "public"
  }
}
