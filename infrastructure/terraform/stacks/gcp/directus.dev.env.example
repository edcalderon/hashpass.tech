# Directus development environment template
# Copy this file to directus.dev.env (ignored by git) and fill with real secrets.

# ===========================================
# Directus Core
# ===========================================
DIRECTUS_KEY=<GENERATE_RANDOM_64_HEX>
DIRECTUS_SECRET=<GENERATE_RANDOM_64_HEX>

# ===========================================
# Admin User (First Run Only)
# ===========================================
ADMIN_EMAIL=admin@hashpass.tech
ADMIN_PASSWORD=<CHANGE_ME_ADMIN_PASSWORD>

# ===========================================
# Database (Supabase PostgreSQL)
# ===========================================
DB_HOST=<SUPABASE_DB_HOST>
DB_PORT=5432
DB_NAME=postgres
DB_USER=<SUPABASE_DB_USER>
DB_PASSWORD=<SUPABASE_DB_PASSWORD>
DB_SSL=true

# ===========================================
# Public URL
# ===========================================
PUBLIC_URL=https://sso-dev.hashpass.co
DIRECTUS_HOST=127.0.0.1
DIRECTUS_PORT=8055

# ===========================================
# Authentication Provider Configuration
# ===========================================
AUTH_PROVIDER=directus
AUTH_PROVIDERS=local,google
AUTH_LOCAL_DRIVER=local

# ===========================================
# Directus SSO Configuration
# ===========================================
DIRECTUS_URL=https://sso-dev.hashpass.co
EXPO_PUBLIC_DIRECTUS_URL=https://sso-dev.hashpass.co
DIRECTUS_ADMIN_EMAIL=admin@hashpass.tech

# Google OAuth Configuration
GOOGLE_CLIENT_ID=<GOOGLE_OAUTH_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<GOOGLE_OAUTH_CLIENT_SECRET>
AUTH_GOOGLE_DRIVER=openid
AUTH_GOOGLE_ISSUER_URL=https://accounts.google.com
AUTH_GOOGLE_IDENTIFIER_KEY=email
AUTH_GOOGLE_SCOPE=openid profile email
AUTH_GOOGLE_MODE=session
AUTH_GOOGLE_ALLOW_PUBLIC_REGISTRATION=true
AUTH_GOOGLE_REDIRECT_ALLOW_LIST=http://localhost:8081/auth/callback,https://sso.hashpass.co/auth/callback,https://sso.hashpass.co/admin,https://sso-dev.hashpass.co/auth/callback,https://sso-dev.hashpass.co/admin,https://blockchainsummit.hashpass.lat/auth/callback,https://blockchainsummit-dev.hashpass.lat/auth/callback,https://api-dev.hashpass.tech/auth/callback,https://api.hashpass.tech/auth/callback

# Local cookie behavior for OAuth callback/session checks
SESSION_COOKIE_SAME_SITE=lax

# Default role for new OAuth users
DEFAULT_ROLE_ID=<DIRECTUS_DEFAULT_ROLE_ID>

# ===========================================
# Optional Supabase Variables (legacy integrations)
# ===========================================
EXPO_PUBLIC_SUPABASE_URL=<SUPABASE_PROJECT_URL>
EXPO_PUBLIC_SUPABASE_KEY=<SUPABASE_ANON_OR_PUBLISHABLE_KEY>
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>

# ===========================================
# CORS
# ===========================================
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:8081,https://hashpass.co,https://www.hashpass.co,https://sso.hashpass.co,https://sso-dev.hashpass.co,https://hashpass.tech,https://blockchainsummit.hashpass.lat,https://blockchainsummit-dev.hashpass.lat,https://api-dev.hashpass.tech,https://api.hashpass.tech
CORS_CREDENTIALS=true
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Cache-Control,Pragma,Expires

# ===========================================
# Other
# ===========================================
WEBSOCKETS_ENABLED=true
NODE_ENV=production
STORAGE_LOCATIONS=local
STORAGE_LOCAL_DRIVER=local
STORAGE_LOCAL_ROOT=./uploads
EMAIL_TRANSPORT=sendmail
SMTP_HOST=
