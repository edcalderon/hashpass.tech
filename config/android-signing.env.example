# Android signing credentials for local Fastlane builds.
# Copy this file to android-signing.env and fill in your values.
# android-signing.env is gitignored — never commit it.
#
# To export the keystore from Expo EAS:
#   npx eas-cli credentials --platform android
#   (choose your project, export keystore, save to config/hashpass-release.keystore)
#
# For the DEVELOPMENT environment, use the dev project credentials:
#   EXPO_TOKEN_DEV must be set (in root .env or env)
#   EAS_PROJECT_ID_DEV must be set (in root .env or env)

# Path to the keystore file — relative to repo root or absolute
ANDROID_KEYSTORE_PATH=config/hashpass-release.keystore

# Keystore password set when the keystore was created in Expo EAS
ANDROID_KEYSTORE_PASSWORD=

# Key alias inside the keystore (Expo EAS typically uses "key0")
ANDROID_KEY_ALIAS=

# Key password (often the same as ANDROID_KEYSTORE_PASSWORD)
ANDROID_KEY_PASSWORD=
