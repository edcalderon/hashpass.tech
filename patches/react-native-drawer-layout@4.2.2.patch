@@ -135,9 +135,17 @@ export function Drawer({
     touchX.value = 0;
     translationX.value = withSpring(translateX, {
       velocity,
-      stiffness: 1000,
-      damping: 500,
-      mass: 3,
+      // HASHPASS patch: the upstream default (stiffness 1000, damping 500,
+      // mass 3) is heavily overdamped (damping ratio ~4.6) and heavy, so the
+      // drawer creeps slowly toward its target and visually looks like it
+      // "stops partway" — users reported it feeling slow and needing a second
+      // tap to fully open/close. These values are near-critically-damped and
+      // light (ratio ~1.0, mass 1) for a fast, single-motion open/close that
+      // still clamps cleanly at the target (overshootClamping) and preserves
+      // the swipe-velocity handoff (the `velocity` field above).
+      stiffness: 600,
+      damping: 45,
+      mass: 1,
       overshootClamping: true,
       restDisplacementThreshold: 0.01,
       restSpeedThreshold: 0.01,
