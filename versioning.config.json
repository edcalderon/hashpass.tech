{
  "rootPackageJson": "package.json",
  "packages": [
    ".",
    "apps/*",
    "packages/*",
    "tools/*",
    "scripts/*",
    "infrastructure/*",
    "lambda/*",
    "aws/*",
    "cloudflare/*",
    "db/*",
    "config/*",
    "tests/*"
  ],
  "changelogFile": "CHANGELOG.md",
  "conventionalCommits": true,
  "syncDependencies": true,
  "ignorePackages": [],
  "extensions": [],
  "extensionConfig": {
    "cleanup-repo": {
      "enabled": true,
      "defaultDestination": "docs",
      "allowlist": [
        ".gitignore",
        ".npmrc",
        "CHANGELOG.md",
        "LICENSE",
        "README.md",
        "SECURITY.md",
        "amplify-hashpass-tech.yml",
        "amplify.yml",
        "amplifyconfiguration.json",
        "app.json",
        "aws-exports.js",
        "babel.config.js",
        "docker-compose.yml",
        "eslint.config.js",
        "expo-env.d.ts",
        "lingui.config.cjs",
        "metro.config.js",
        "nativewind-env.d.ts",
        "netlify.toml",
        "package-lock.json",
        "package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "postcss.config.js",
        "tailwind.config.js",
        "tsconfig.json",
        "tsconfig.paths.json",
        "turbo.json",
        "versioning.config.json",
        "workbox-config.js",
        "wrangler.jsonc",
        "wrangler.toml",
        "wrangler.toml.example"
      ],
      "routes": {
        ".js": "tools/scripts",
        ".sh": "tools/scripts",
        ".md": "docs",
        ".json": "config",
        ".yml": "config",
        ".yaml": "config",
        ".toml": "config",
        ".jsonc": "config"
      }
    },
    "secrets-check": {
      "enabled": true,
      "patterns": [
        "CUSTOM_API_KEY[=:][0-9a-f]{32}",
        "(SUPABASE|DIRECTUS|GOOGLE|AWS|BREVO|NODEMAILER|DB)_(KEY|SECRET|PASSWORD|PASS|ROLE|URL|USER)[^=:\"']*[:=][\\s\"']*[A-Za-z0-9._/-]{10,}",
        "eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}",
        "sb_publishable_[A-Za-z0-9_-]{20,}",
        "xkeysib-[a-zA-Z0-9]{32,}",
        "xsmtpsib-[a-zA-Z0-9]{32,}",
        "AIza[0-9A-Za-z-_]{35}",
        "aws_access_key_id[\\s\"']*[:=][\\s\"']*[A-Z0-9]{20}",
        "aws_secret_access_key[\\s\"']*[:=][\\s\"']*[A-Za-z0-9/+=]{40}"
      ],
      "allowlist": []
    },
    "lifecycle-hooks": {
      "enabled": true,
      "hooks": {
        "postRelease": {
          "main": "npm run deploy:prod",
          "develop": "npm run deploy:staging"
        }
      }
    }
  },
  "branchAwareness": {
    "enabled": false,
    "defaultBranch": "main",
    "branches": {
      "main": {
        "versionFormat": "semantic",
        "tagFormat": "v{version}",
        "syncFiles": [
          "package.json"
        ],
        "environment": "production",
        "bumpStrategy": "semantic"
      },
      "develop": {
        "versionFormat": "dev",
        "tagFormat": "v{version}",
        "syncFiles": [
          "version.development.json"
        ],
        "environment": "development",
        "bumpStrategy": "dev-build"
      },
      "feature/*": {
        "versionFormat": "feature",
        "tagFormat": "v{version}",
        "syncFiles": [
          "version.development.json"
        ],
        "environment": "development",
        "bumpStrategy": "feature-branch"
      },
      "hotfix/*": {
        "versionFormat": "hotfix",
        "tagFormat": "v{version}",
        "syncFiles": [
          "version.development.json"
        ],
        "environment": "development",
        "bumpStrategy": "hotfix"
      }
    }
  }
}