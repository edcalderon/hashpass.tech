# HashPass Infrastructure Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Directus Core
# ===========================================
# Generate these with: openssl rand -hex 32
DIRECTUS_KEY=your-super-long-random-key-here
DIRECTUS_SECRET=your-super-long-secret-here

# ===========================================
# Admin User (First Run Only)
# ===========================================
ADMIN_EMAIL=admin@hashpass.tech
ADMIN_PASSWORD=StrongPassword123!

# ===========================================
# Database (Supabase PostgreSQL)
# ===========================================
# Format: db.xxxxx.supabase.co
DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-password
DB_SSL=true

# ===========================================
# Public URL
# ===========================================
# For production: https://sso.hashpass.co (with HTTPS)
# For local development: http://localhost:8055 (HTTP is OK for localhost)
# For local network testing: http://192.168.x.x:8055 (set DIRECTUS_HOST=0.0.0.0 in docker-compose)
PUBLIC_URL=https://sso.hashpass.co

# ===========================================
# Authentication
# ===========================================
# Comma-separated: local,google,discord
AUTH_PROVIDERS=local
AUTH_LOCAL_DRIVER=local

# Token TTL
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Default role ID for new users (get from Directus after setup)
DEFAULT_ROLE_ID=

# ===========================================
# OAuth: Google
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_DRIVER=openid
AUTH_GOOGLE_ISSUER_URL=https://accounts.google.com
AUTH_GOOGLE_IDENTIFIER_KEY=email
AUTH_GOOGLE_SCOPE=openid profile email
AUTH_GOOGLE_MODE=session
AUTH_GOOGLE_ALLOW_PUBLIC_REGISTRATION=true
AUTH_GOOGLE_REDIRECT_ALLOW_LIST=http://localhost:8081/auth/callback,https://sso.hashpass.co/auth/callback
SESSION_COOKIE_SAME_SITE=lax

# ===========================================
# OAuth: Discord
# ===========================================
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ===========================================
# Storage (S3/GCS)
# ===========================================
# Driver: s3 or gcs
STORAGE_DRIVER=s3

# S3/GCS Configuration
STORAGE_BUCKET=hashpass-assets
STORAGE_REGION=us-central1
STORAGE_KEY=your-access-key
STORAGE_SECRET=your-secret-key

# For GCS or S3-compatible storage
# STORAGE_ENDPOINT=https://storage.googleapis.com

# ===========================================
# Email (SMTP)
# ===========================================
EMAIL_FROM=noreply@hashpass.tech
EMAIL_TRANSPORT=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# ===========================================
# CORS
# ===========================================
# Comma-separated list of allowed origins
CORS_ORIGIN=https://hashpass.tech,https://www.hashpass.tech,http://localhost:8081
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Cache-Control,Pragma,Expires

# ===========================================
# Logging
# ===========================================
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
