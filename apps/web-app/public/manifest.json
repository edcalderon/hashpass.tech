{
  "name": "HashPass",
  "short_name": "HashPass",
  "id": "/",
  "description": "Secure password management and sharing",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "prefer_related_applications": true,
  "background_color": "#ffffff",
  "theme_color": "#000000",
  "orientation": "portrait",
  "permissions": [
    "camera"
  ],
  "related_applications": [
    {
      "platform": "webapp",
      "url": "/manifest.json",
      "id": "/"
    }
  ],
  "splash_image": "/assets/splash.gif",
  "splash_color": "#ffffff",
  "icons": [
    {
      "src": "/assets/android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/assets/android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ]
}
