# Required for Supabase Auth
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for Directus SSO
DIRECTUS_URL=https://sso.hashpass.co
EXPO_PUBLIC_DIRECTUS_URL=https://sso.hashpass.co
# Optional API base for OAuth proxy and version checks.
# Local development: http://localhost:8081/api
EXPO_PUBLIC_API_BASE_URL=
DIRECTUS_OAUTH_SUPABASE_SYNC_ENABLED=true
DIRECTUS_OAUTH_SUPABASE_BRIDGE_ENABLED=true
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Required for OTP Emails (Nodemailer)
NODEMAILER_HOST=
NODEMAILER_PORT=587
NODEMAILER_USER=
NODEMAILER_PASS=
NODEMAILER_FROM=info@hashpass.tech

# Required for OTP SMS (Brevo)
BREVO_API_KEY=
BREVO_SMS_SENDER=HASHPASS
