# Required for Supabase Auth
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional tenant-specific Supabase profiles.
# These avoid duplicate generic keys when one branch serves multiple tenants.
EXPO_PUBLIC_SUPABASE_PROFILE=core-development
SUPABASE_PROFILE=core-development
EXPO_PUBLIC_BSL_SUPABASE_URL_DEV=
EXPO_PUBLIC_BSL_SUPABASE_KEY_DEV=
BSL_SUPABASE_SERVICE_ROLE_KEY_DEV=
BSL_SUPABASE_DB_URL_DEV=
EXPO_PUBLIC_BSL_SUPABASE_URL_PROD=
EXPO_PUBLIC_BSL_SUPABASE_KEY_PROD=
BSL_SUPABASE_SERVICE_ROLE_KEY_PROD=
BSL_SUPABASE_DB_URL_PROD=

# BSL-only Better Auth social login.
# Main hashpass.tech still uses Directus. BSL frontend should point to the API-hosted Better Auth route.
EXPO_PUBLIC_BETTER_AUTH_URL=https://api-dev.hashpass.tech/api/bsl-auth
EXPO_PUBLIC_BETTER_AUTH_BASE_PATH=/api/bsl-auth
BETTER_AUTH_URL=https://api-dev.hashpass.tech/api/bsl-auth
BETTER_AUTH_BASE_PATH=/api/bsl-auth
BETTER_AUTH_SECRET=
BETTER_AUTH_DATABASE_URL=
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:8081,https://bsl-dev.hashpass.tech,https://api-dev.hashpass.tech
BETTER_AUTH_GOOGLE_CLIENT_ID=
BETTER_AUTH_GOOGLE_CLIENT_SECRET=

# Required for Directus SSO
DIRECTUS_URL=https://sso.hashpass.co
EXPO_PUBLIC_DIRECTUS_URL=https://sso.hashpass.co
# Optional API base for OAuth proxy and version checks.
# Local development: http://localhost:8081/api
EXPO_PUBLIC_API_BASE_URL=
DIRECTUS_OAUTH_SUPABASE_SYNC_ENABLED=true
DIRECTUS_OAUTH_SUPABASE_BRIDGE_ENABLED=true
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Required for OTP Emails (Nodemailer)
NODEMAILER_HOST=
NODEMAILER_PORT=587
NODEMAILER_USER=
NODEMAILER_PASS=
NODEMAILER_FROM=info@hashpass.tech

# Required for OTP SMS (Brevo)
BREVO_API_KEY=
BREVO_SMS_SENDER=HASHPASS
