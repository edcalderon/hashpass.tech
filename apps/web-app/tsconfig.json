{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@hashpass/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@hashpass/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@hashpass/utils": [
        "../../packages/utils/src/index.ts"
      ],
      "@hashpass/utils/*": [
        "../../packages/utils/src/*"
      ],
      "@hashpass/types": [
        "../../packages/types/src/index.ts"
      ],
      "@hashpass/types/*": [
        "../../packages/types/src/*"
      ],
      "@hashpass/i18n": [
        "../../packages/i18n/src/index.ts"
      ],
      "@hashpass/i18n/*": [
        "../../packages/i18n/src/*"
      ],
      "@/*": ["./*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
