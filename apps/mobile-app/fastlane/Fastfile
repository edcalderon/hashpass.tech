default_platform(:android)

FASTLANE_TRACKS = %w[internal production].freeze
GOOGLE_PLAY_JSON_KEY = ENV.fetch(
  'GOOGLE_PLAY_JSON_KEY',
  File.expand_path('../../../config/hashpass-eas.json', __dir__),
).freeze
PACKAGE_NAME = 'com.hashpass.tech'.freeze

def env_value(*names)
  names.each do |name|
    value = ENV[name]
    next if value.nil?

    stripped = value.to_s.strip
    return stripped unless stripped.empty?
  end

  nil
end

def resolve_android_signing_properties
  store_file = env_value('ANDROID_KEYSTORE_PATH', 'ANDROID_RELEASE_KEYSTORE_PATH')
  store_password = env_value('ANDROID_KEYSTORE_PASSWORD', 'ANDROID_RELEASE_KEYSTORE_PASSWORD')
  key_alias = env_value('ANDROID_KEY_ALIAS', 'ANDROID_RELEASE_KEY_ALIAS')
  key_password = env_value('ANDROID_KEY_PASSWORD', 'ANDROID_RELEASE_KEY_PASSWORD')

  missing = []
  missing << 'ANDROID_KEYSTORE_PATH' unless store_file
  missing << 'ANDROID_KEYSTORE_PASSWORD' unless store_password
  missing << 'ANDROID_KEY_ALIAS' unless key_alias
  missing << 'ANDROID_KEY_PASSWORD' unless key_password

  unless missing.empty?
    UI.user_error!(
      "Missing Android signing secrets for fastlane release: #{missing.join(', ')}. " +
      'Set them in the GitHub Actions workflow or export them locally before building.',
    )
  end

  unless File.exist?(store_file)
    UI.user_error!("Android keystore file not found: #{store_file}")
  end

  {
    'android.injected.signing.store.file' => store_file,
    'android.injected.signing.store.password' => store_password,
    'android.injected.signing.key.alias' => key_alias,
    'android.injected.signing.key.password' => key_password,
  }
end

def normalize_track(value)
  track = value.to_s.strip.downcase

  return 'internal' if track.empty?

  unless FASTLANE_TRACKS.include?(track)
    UI.user_error!("Unsupported Google Play track: #{value}")
  end

  track
end

def build_android_bundle
  gradle(
    task: 'bundle',
    build_type: 'Release',
    project_dir: 'android',
    properties: resolve_android_signing_properties,
    flags: '--stacktrace',
    print_command: true,
    print_command_output: true
  )

  lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]
end

platform :android do
  desc 'Build the Android App Bundle without uploading it.'
  lane :build do |_options|
    build_android_bundle
  end

  desc 'Build the Android App Bundle and upload it to Google Play.'
  lane :release do |options|
    track = normalize_track(options[:track] || ENV['FASTLANE_TRACK'])
    release_status = (options[:release_status] || ENV['FASTLANE_RELEASE_STATUS'] || 'completed').to_s
    aab_path = build_android_bundle

    upload_to_play_store(
      aab: aab_path,
      track: track,
      release_status: release_status,
      package_name: PACKAGE_NAME,
      json_key: GOOGLE_PLAY_JSON_KEY,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end
end
