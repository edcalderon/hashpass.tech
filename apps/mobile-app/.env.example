# Required for Supabase Auth
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Frontend origin used by auth redirects.
# Set this to your dev site or tunnel URL for local passwordless testing.
EXPO_PUBLIC_FRONTEND_URL=
FRONTEND_URL=

# EAS project link for Android/iOS build and submission flows.
EAS_PROJECT_ID=
EAS_PROJECT_ID_DEV=

# Optional tenant-specific Supabase profiles.
# These avoid duplicate generic keys when one branch serves multiple tenants.
EXPO_PUBLIC_SUPABASE_PROFILE=core-development
SUPABASE_PROFILE=core-development
EXPO_PUBLIC_BSL_SUPABASE_URL_DEV=
EXPO_PUBLIC_BSL_SUPABASE_KEY_DEV=
BSL_SUPABASE_SERVICE_ROLE_KEY_DEV=
BSL_SUPABASE_DB_URL_DEV=
EXPO_PUBLIC_BSL_SUPABASE_URL_PROD=
EXPO_PUBLIC_BSL_SUPABASE_KEY_PROD=
BSL_SUPABASE_SERVICE_ROLE_KEY_PROD=
BSL_SUPABASE_DB_URL_PROD=

# Event tenant filtering.
# Leave blank in production so the hostname is authoritative:
# - hashpass.tech => main/global explorer
# - bsl.hashpass.tech and bsl-dev.hashpass.tech => BSL event family
# For local testing, set EXPO_PUBLIC_EVENT_TENANT=main, bsl, or bsl2025.
# For exact local/custom filtering, set EXPO_PUBLIC_EVENT_IDS=bsl,bsl2025.
EXPO_PUBLIC_EVENT_TENANT=
EXPO_PUBLIC_EVENT_IDS=

# Event Better Auth social login.
# Main hashpass.tech still uses Directus. Event frontends should point to the shared API-hosted /auth route.
EXPO_PUBLIC_BETTER_AUTH_URL=https://api-dev.hashpass.tech/api/auth
EXPO_PUBLIC_BETTER_AUTH_BASE_PATH=/api/auth
BETTER_AUTH_URL=https://api-dev.hashpass.tech/api/auth
BETTER_AUTH_BASE_PATH=/api/auth
BETTER_AUTH_SECRET=
BETTER_AUTH_DATABASE_URL=
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081,https://hashpass.tech,https://www.hashpass.tech,https://hashpass.co,https://www.hashpass.co,https://bsl.hashpass.tech,https://bsl-dev.hashpass.tech,https://bsl2025.hashpass.tech,https://bsl2025.hashpass.co,https://blockchainsummit.hashpass.lat,https://blockchainsummit-dev.hashpass.lat,https://api.hashpass.tech,https://api-dev.hashpass.tech
BETTER_AUTH_GOOGLE_CLIENT_ID=
BETTER_AUTH_GOOGLE_CLIENT_SECRET=

# Auth provider selection. EXPO_PUBLIC_ prefix is required so Metro inlines it
# into the React Native JS bundle; AUTH_PROVIDER (no prefix) works only server-side.
# Leave these unset to let the runtime infer the provider from the host.
# Values: directus | supabase | better-auth
EXPO_PUBLIC_AUTH_PROVIDER=
AUTH_PROVIDER=

# Required for Directus SSO
DIRECTUS_URL=https://sso.hashpass.co
EXPO_PUBLIC_DIRECTUS_URL=https://sso.hashpass.co
# Optional API base for OAuth proxy and version checks.
# Local development: http://localhost:8081/api
EXPO_PUBLIC_API_BASE_URL=
DIRECTUS_OAUTH_SUPABASE_SYNC_ENABLED=true
DIRECTUS_OAUTH_SUPABASE_BRIDGE_ENABLED=true
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Native Google Sign-In (iOS/Android — no browser popup)
# Defaults to true on native builds so the SDK account-picker flow is used.
# Set to false to temporarily fall back to the browser-based OAuth flow.
EXPO_PUBLIC_NATIVE_GOOGLE_SIGNIN=true
# Web Client ID from Google Cloud Console (type=Web, NOT Android).
# Required when EXPO_PUBLIC_NATIVE_GOOGLE_SIGNIN=true.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Required for OTP Emails (Nodemailer)
NODEMAILER_HOST=
NODEMAILER_PORT=587
NODEMAILER_USER=
NODEMAILER_PASS=
NODEMAILER_FROM=info@hashpass.tech

# Required for OTP SMS (Brevo)
BREVO_API_KEY=
BREVO_SMS_SENDER=HASHPASS
