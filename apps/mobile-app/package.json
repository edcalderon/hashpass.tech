    "@types/react-native": "^0.72.8",
    "@types/react-navigation": "^3.0.8",
    "@types/react-test-renderer": "^18.3.0",
    "argon2": "^0.44.0",
    "chromedriver": "^142.0.1",
    "css-loader": "^7.1.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~9.2.0",
    "expo-module-scripts": "^4.1.9",
    "husky": "^9.1.7",
