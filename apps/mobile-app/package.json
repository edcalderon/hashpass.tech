    "expo": "^53.0.0",
    "expo-atlas": "^0.4.0",
    "expo-auth-session": "^6.2.1",
    "expo-blur": "~14.1.4",
    "expo-camera": "~16.1.9",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.5",
    "expo-font": "~13.3.1",
    "expo-gl": "~15.1.7",
