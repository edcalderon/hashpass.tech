{
  "name": "hashpass-mobile-app",
  "version": "1.8.17",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "main": "expo-router/entry",
  "scripts": {
    "start": "NODE_OPTIONS='--max-old-space-size=6144' expo start",
    "start:reset": "NODE_OPTIONS='--max-old-space-size=6144' expo start --clear",
    "android": "NODE_OPTIONS='--max-old-space-size=6144' expo start --android",
    "android:bundle": "node ../../packages/tools/scripts/run-mobile-eas.js build --platform android --profile production",
    "android:bundle:dev": "node ../../packages/tools/scripts/run-mobile-eas.js build --platform android --profile preview",
    "android:publish": "node ../../packages/tools/scripts/run-mobile-eas.js submit --platform android --profile production --latest",
    "android:publish:dev": "node ../../packages/tools/scripts/run-mobile-eas.js submit --platform android --profile preview --latest",
    "android:release": "node ../../packages/tools/scripts/run-mobile-release.js --env production",
    "android:release:dev": "node ../../packages/tools/scripts/run-mobile-release.js --env development",
    "android:release:eas": "node ../../packages/tools/scripts/run-mobile-release.js --backend eas --env production",
    "android:release:eas:dev": "node ../../packages/tools/scripts/run-mobile-release.js --backend eas --env development",
    "android:release:fastlane": "node ../../packages/tools/scripts/run-mobile-release.js --backend fastlane --env production",
    "android:release:fastlane:dev": "node ../../packages/tools/scripts/run-mobile-release.js --backend fastlane --env development",
    "ios": "NODE_OPTIONS='--max-old-space-size=6144' expo start --ios",
    "web": "NODE_OPTIONS='--max-old-space-size=6144' expo start --web --clear --port ${EXPO_WEB_PORT:-8081}",
    "env:propagate": "node ../../packages/tools/scripts/propagate-env.js",
    "dev": "npm run env:propagate local && NODE_OPTIONS='--max-old-space-size=6144' expo start --web --clear --port ${EXPO_WEB_PORT:-8081}",
    "build": "if [ \"${SKIP_ENV_PROPAGATE:-0}\" != \"1\" ]; then npm run env:propagate ${BUILD_ENV:-production}; fi && npm run prebuild && node ../../packages/tools/scripts/update-sw-version.mjs && node ../../packages/tools/scripts/patch-expo-api-route-sourcemaps.mjs && NODE_OPTIONS=\"--max-old-space-size=${NODE_MAX_OLD_SPACE_SIZE:-6144}\" expo export -p web --max-workers ${EXPO_EXPORT_MAX_WORKERS:-2} && if [ \"${SKIP_WEB_POSTBUILD:-0}\" != \"1\" ]; then npm run postbuild:web; fi",
    "build:static": "if [ \"${SKIP_ENV_PROPAGATE:-0}\" != \"1\" ]; then npm run env:propagate ${BUILD_ENV:-production}; fi && npm run prebuild && node ../../packages/tools/scripts/update-sw-version.mjs && node ../../packages/tools/scripts/patch-expo-api-route-sourcemaps.mjs && NODE_OPTIONS=\"--max-old-space-size=${NODE_MAX_OLD_SPACE_SIZE:-6144}\" expo export -p web --max-workers ${EXPO_EXPORT_MAX_WORKERS:-2} && if [ \"${SKIP_WEB_POSTBUILD:-0}\" != \"1\" ]; then npm run postbuild:static; fi",
    "prebuild": "rm -rf dist",
    "postbuild:web": "mkdir -p dist/config && cp config/versions.json dist/config/versions.json 2>/dev/null || true && if [ -f dist/server/index.html ] && [ ! -f dist/client/index.html ]; then mkdir -p dist/client && cp dist/server/index.html dist/client/index.html; fi && cp public/sw.js dist/sw.js 2>/dev/null || true && node scripts/patch-web-seo.mjs",
    "postbuild:static": "if [ -d dist/server ]; then cp -R dist/server/. dist/; fi && if [ -d dist/client/_expo ]; then mkdir -p dist/_expo && cp -R dist/client/_expo/. dist/_expo/; fi && if [ -d dist/client/assets ]; then mkdir -p dist/assets && cp -R dist/client/assets/. dist/assets/; fi && mkdir -p dist/config && cp config/versions.json dist/config/versions.json 2>/dev/null || true && if [ -f dist/server/index.html ] && [ ! -f dist/client/index.html ]; then mkdir -p dist/client && cp dist/server/index.html dist/client/index.html; fi && cp public/sw.js dist/sw.js 2>/dev/null || true && node scripts/patch-web-seo.mjs",
    "lint": "expo lint",
    "test": "jest --watchAll"
  },
  "dependencies": {
    "@adraffy/ens-normalize": "^1.11.1",
    "@aws-sdk/client-s3": "^3.929.0",
    "@aws-sdk/s3-request-presigner": "^3.927.0",
    "@babel/core": "^7.25.2",
