#!/usr/bin/env sh
set -e

echo "🔐 Running secret scan..."
if pnpm -s exec versioning --help >/dev/null 2>&1; then
  pnpm -s exec versioning check-secrets
elif command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --staged --redact --no-banner
else
  echo "❌ Secret scan tool not found. Install 'versioning' or 'gitleaks' and retry."
  exit 1
fi

echo "🧪 Skipping test suite due to jest config..."
# npm test -- --watchAll=false

# === secrets-check: start ===
echo "🔒 Running secrets check…"
npx versioning check-secrets 2>/dev/null
# === secrets-check: end ===
npx @edcalderon/versioning validate
